#!/usr/bin/env fish
# ryBlock вҖ” neo-tokyo firewall for your hosts file
# blocks sites via /etc/hosts, serves a neon "OFF LIMITS" page on 127.0.0.1

set -g RB_HOSTS /etc/hosts
set -q RYBLOCK_HOSTS; and set -g RB_HOSTS $RYBLOCK_HOSTS

set -g RB_BEGIN '# >>> ryBlock >>> (managed block вҖ” do not edit by hand)'
set -g RB_END   '# <<< ryBlock <<<'
set -g RB_DIR   (dirname (realpath (status --current-filename)))
set -g RB_PIDFILE /var/run/ryblock.pid

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ cosmetics в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# vibrant neon palette вҖ” truecolor, falls back to nearest 256/16 on old terms
set -g _rb_pink  (set_color -o ff2a6d)   # hot magenta
set -g _rb_cyan  (set_color -o 05d9e8)   # electric cyan
set -g _rb_dim   (set_color 6d5a9c)      # dim violet
set -g _rb_red   (set_color -o ff3860)
set -g _rb_grn   (set_color -o 39ff14)   # neon green
set -g _rb_yel   (set_color -o fee440)   # neon amber
set -g _rb_off   (set_color normal)

# skyline-only shades (back-to-front neon gradient)
set -g _rb_sky   (set_color b98bff)      # moon / stars
set -g _rb_far   (set_color 7b4bd8)      # distant towers
set -g _rb_t1    (set_color -o 2ff3ff)   # rooftops
set -g _rb_t2    (set_color -o 15c9f5)   # upper floors
set -g _rb_t3    (set_color -o c74bff)   # mid floors (windows)
set -g _rb_t4    (set_color -o ff2a6d)   # lower floors (windows)

